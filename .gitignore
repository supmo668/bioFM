# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Editor / OS
.vscode/
.idea/
.DS_Store

# Secrets — never commit
.env
.env.*
!.env.example
*.key
*.pem
credentials.json

# Demo outputs
projects/**/results.jsonl
projects/**/*.png

# Don't track HF weights if accidentally downloaded in-repo
**/*.safetensors
**/*.bin
**/pytorch_model*

# Upstream reference repos live as submodules (see .gitmodules).
# git tracks the submodule pointers; files inside each submodule are governed
# by each submodule's own .gitignore.

# Claude Code machine-local runtime state (skill caches, schedule lock files,
# per-machine tool configs). Not part of the project — ignore everywhere.
.claude/

# Git worktrees — isolated dev branches live here; each is its own checkout.
.worktrees/

# Scratch directory used by scripts/publish/submit_to_venues.py to zip
# upload bundles. Build artefacts, not source.
projects/perturb-seq-eval/.publish_work/
projects/*/.publish_work/
.publish_work/

