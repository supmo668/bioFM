# -----------------------------------------------------------------------------
# .env.example — copy to `.env` and fill in.
#
# The real `.env` file is gitignored (see .gitignore: `.env` +
# `!.env.example` allow-list). `.env` is auto-loaded at the start of every
# script that needs secrets (e.g. `scripts/publish/submit_to_venues.py`).
#
# Leave a variable blank or prefixed with REPLACE_ME if you have not signed
# up for that service yet — the consuming script will warn per-venue and
# skip the corresponding step.
# -----------------------------------------------------------------------------

# ---- OpenRouter (LLM rater for perturb-seq-eval live smoke) -----------------
# Signup: https://openrouter.ai  → Keys page
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=https://github.com/your-org/your-repo
OPENROUTER_APP_TITLE=perturb-seq-eval

# ---- Zenodo (preprint + supplement DOI) -------------------------------------
# Signup:  https://zenodo.org/signup
# Token:   Settings → Applications → Personal access tokens → New token
# Scopes:  deposit:write  AND  deposit:actions
# Leave blank to skip Zenodo submission.
ZENODO_TOKEN=REPLACE_ME

# ---- Figshare (second-source DOI + artifact mirror) -------------------------
# Signup:  https://figshare.com
# Token:   user icon → Applications → Personal tokens → Create Personal Token
# Leave blank to skip Figshare submission.
FIGSHARE_TOKEN=REPLACE_ME

# ---- OSF / BioHackrXiv (community-visible preprint) -------------------------
# Signup:  https://osf.io
# Token:   Settings → Personal access tokens → Create token (scope: osf.full_write)
# Leave blank to skip OSF submission.
OSF_TOKEN=REPLACE_ME

# ---- Modal (optional — already configured via ~/.modal.toml by `modal setup`)
# If you prefer env-var auth instead of ~/.modal.toml, uncomment:
# MODAL_TOKEN_ID=ak-REPLACE_ME
# MODAL_TOKEN_SECRET=as-REPLACE_ME
