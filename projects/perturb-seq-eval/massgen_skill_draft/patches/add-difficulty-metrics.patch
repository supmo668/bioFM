--- /dev/null
+++ b/massgen/learning/difficulty_metrics.py
@@ -0,0 +1,349 @@
+"""Difficulty-metrics observer for MassGen coordination sessions.
+
+Overview
+--------
+The observer consumes :class:`massgen.coordination_tracker.CoordinationEvent`
+records alongside the :class:`AgentAnswer` and :class:`AgentVote` dataclasses
+already emitted by the orchestrator, and produces per-round metrics:
+
+* **ACE** — Shannon entropy of the softmax-normalised per-agent
+  vote-share distribution.  Low = one agent dominates; high = flat.
+* **CSD** — variance of the per-voter critique severities.  Severities
+  are obtained from an injected rater callable; the default rater is
+  the vote-share itself (deterministic, no LLM).
+* **ΔACE, ΔC, WFR** — round-over-round convergence signals.
+* **TDI** — convex combination of the above four; coefficients
+  configurable.
+
+Design
+------
+* **No third-party metric library.** We implement ACE/variance in
+  pure Python with ``statistics`` so the module runs in any MassGen
+  install without numpy/scipy.  The orchestrator's existing test
+  harness already uses ``statistics``, keeping the dependency surface
+  unchanged.
+* **Anti-pattern compliance.** The default severity rater is the
+  *vote-share* projection (no text parsing).  An LLM-based rater can
+  be injected by the caller; ``massgen/skills/perturb-seq-eval/``
+  ships one that follows the upstream "no keyword/heuristic matching"
+  rule by delegating to a rater model.
+* **Config-gated.** Until
+  ``orchestrator.coordination.learning_difficulty_metrics`` is
+  ``true``, the observer is never instantiated.  When enabled it
+  attaches as a listener on the tracker's event bus.
+
+External surface
+----------------
+``DifficultyMetricsObserver`` exposes three methods:
+- ``on_round_end(round_index, answers, votes) -> dict`` — returns the
+  per-round metrics for inspection / logging.
+- ``snapshot() -> dict`` — returns the aggregated run-level metrics.
+- ``as_run_trace()`` — returns a JSON-serialisable dict that the
+  optional downstream ``perturb_eval`` package can consume.
+"""
+
+from __future__ import annotations
+
+import math
+import statistics
+from collections import Counter
+from dataclasses import dataclass, field
+from typing import Any, Callable, Iterable, Protocol
+
+
+# ---------------------------------------------------------------------------
+# Pluggable rater protocol
+# ---------------------------------------------------------------------------
+
+class SeverityRater(Protocol):
+    """Rate a single vote-reason string on a 0.0-1.0 severity scale."""
+
+    def __call__(self, *, voter_id: str, voted_for: str,
+                 answer_labels: list[str], reason_text: str) -> float: ...
+
+
+def _share_based_severity_rater(
+    *,
+    voter_id: str,
+    voted_for: str,
+    answer_labels: list[str],
+    reason_text: str,
+    vote_shares: dict[str, float],
+) -> float:
+    """Default severity = 1 - (vote-share of voted_for)."""
+    _ = voter_id, reason_text, answer_labels
+    return max(0.0, min(1.0, 1.0 - vote_shares.get(voted_for, 0.0)))
+
+
+# ---------------------------------------------------------------------------
+# Dataclasses
+# ---------------------------------------------------------------------------
+
+@dataclass(frozen=True)
+class TDICoefficients:
+    """Convex-combination weights for the composite Task Difficulty Index."""
+
+    alpha_ace: float = 0.35
+    beta_csd: float = 0.25
+    gamma_lack_of_conv: float = 0.25
+    delta_wfr: float = 0.15
+
+    def __post_init__(self) -> None:
+        total = (self.alpha_ace + self.beta_csd
+                 + self.gamma_lack_of_conv + self.delta_wfr)
+        if abs(total - 1.0) > 1e-6:
+            raise ValueError(
+                f"TDI coefficients must sum to 1; got {total:.6f}"
+            )
+
+
+@dataclass(frozen=True)
+class ACEConfig:
+    """Hyperparameters for the ACE computation."""
+
+    temperature: float = 1.0
+
+
+@dataclass(frozen=True)
+class DifficultyMetrics:
+    """Per-round metric record."""
+
+    round_index: int
+    agent_ids: tuple[str, ...]
+    ace_norm: float
+    mean_vote_share: float
+    max_vote_share: float
+    csd: float
+    winner: str | None
+    consensus_score: float
+
+
+@dataclass(frozen=True)
+class RunLevelMetrics:
+    """Run-level aggregate metrics."""
+
+    per_round: tuple[DifficultyMetrics, ...]
+    delta_ace: float
+    delta_mean_share: float
+    winner_flip_rate: float
+    tdi: float
+
+
+# ---------------------------------------------------------------------------
+# Observer
+# ---------------------------------------------------------------------------
+
+class DifficultyMetricsObserver:
+    """Accumulates per-round metrics over a MassGen coordination session.
+
+    Wire-up:
+        observer = DifficultyMetricsObserver()
+        # ... orchestrator runs a round ...
+        observer.on_round_end(round_index, answers, votes)
+        # ... at session_end ...
+        run_metrics = observer.snapshot()
+    """
+
+    def __init__(
+        self,
+        *,
+        ace_config: ACEConfig | None = None,
+        tdi_coefficients: TDICoefficients | None = None,
+        rater: SeverityRater | None = None,
+    ) -> None:
+        self.ace_config = ace_config or ACEConfig()
+        self.tdi_coefficients = tdi_coefficients or TDICoefficients()
+        self._rater = rater
+        self._per_round: list[DifficultyMetrics] = []
+
+    # ------------------------------------------------------------------
+    # Public API
+    # ------------------------------------------------------------------
+    def on_round_end(
+        self,
+        round_index: int,
+        answers: Iterable[Any],
+        votes: Iterable[Any],
+    ) -> DifficultyMetrics:
+        """Compute the per-round metric record and stash it.
+
+        ``answers`` / ``votes`` duck-type the MassGen
+        :class:`AgentAnswer` / :class:`AgentVote` dataclasses — we touch
+        only the minimum required attributes.
+        """
+        ans_list = list(answers)
+        vote_list = list(votes)
+        agent_ids = tuple(dict.fromkeys(a.agent_id for a in ans_list))
+        if not agent_ids:
+            # Nothing to measure; emit a null-ish record so downstream code
+            # has a consistent shape.
+            rec = DifficultyMetrics(
+                round_index=round_index,
+                agent_ids=(),
+                ace_norm=0.0,
+                mean_vote_share=0.0,
+                max_vote_share=0.0,
+                csd=0.0,
+                winner=None,
+                consensus_score=0.0,
+            )
+            self._per_round.append(rec)
+            return rec
+
+        shares = self._vote_shares(agent_ids, vote_list)
+        ace_n = self._ace_norm(list(shares.values()), self.ace_config.temperature)
+
+        severities = self._severity_values(agent_ids, vote_list, shares)
+        csd = statistics.pvariance(severities) if len(severities) >= 2 else 0.0
+
+        winner, consensus = self._winner(agent_ids, shares, vote_list)
+
+        mean_share = statistics.fmean(shares.values())
+        max_share = max(shares.values())
+
+        rec = DifficultyMetrics(
+            round_index=round_index,
+            agent_ids=agent_ids,
+            ace_norm=ace_n,
+            mean_vote_share=mean_share,
+            max_vote_share=max_share,
+            csd=csd,
+            winner=winner,
+            consensus_score=consensus,
+        )
+        self._per_round.append(rec)
+        return rec
+
+    def snapshot(self) -> RunLevelMetrics:
+        """Return the run-level aggregate."""
+        per_round = tuple(self._per_round)
+        delta_ace = 0.0
+        delta_mean = 0.0
+        wfr = 0.0
+        if len(per_round) >= 2:
+            delta_ace = per_round[-1].ace_norm - per_round[0].ace_norm
+            delta_mean = per_round[-1].mean_vote_share - per_round[0].mean_vote_share
+            flips = sum(
+                1 for r in range(1, len(per_round))
+                if per_round[r].winner != per_round[r - 1].winner
+            )
+            wfr = flips / (len(per_round) - 1)
+        last = per_round[-1] if per_round else None
+        tdi_val = self._tdi(last, delta_mean, wfr)
+        return RunLevelMetrics(
+            per_round=per_round,
+            delta_ace=delta_ace,
+            delta_mean_share=delta_mean,
+            winner_flip_rate=wfr,
+            tdi=tdi_val,
+        )
+
+    def as_run_trace(self) -> dict[str, Any]:
+        """JSON-serialisable representation for external consumers."""
+        snap = self.snapshot()
+        return {
+            "per_round": [
+                {
+                    "round_index": r.round_index,
+                    "agent_ids": list(r.agent_ids),
+                    "ace_norm": r.ace_norm,
+                    "mean_vote_share": r.mean_vote_share,
+                    "max_vote_share": r.max_vote_share,
+                    "csd": r.csd,
+                    "winner": r.winner,
+                    "consensus_score": r.consensus_score,
+                }
+                for r in snap.per_round
+            ],
+            "delta_ace": snap.delta_ace,
+            "delta_mean_share": snap.delta_mean_share,
+            "winner_flip_rate": snap.winner_flip_rate,
+            "tdi": snap.tdi,
+        }
+
+    # ------------------------------------------------------------------
+    # Math
+    # ------------------------------------------------------------------
+    @staticmethod
+    def _vote_shares(agent_ids: tuple[str, ...], votes: list[Any]) -> dict[str, float]:
+        counts = Counter(
+            v.voted_for for v in votes
+            if getattr(v, "voted_for", None) in agent_ids
+            and getattr(v, "voter_id", None) != getattr(v, "voted_for", None)
+        )
+        distinct_voters = len({v.voter_id for v in votes
+                               if getattr(v, "voter_id", None) is not None})
+        denom = max(1, distinct_voters)
+        return {a: counts.get(a, 0) / denom for a in agent_ids}
+
+    @staticmethod
+    def _ace_norm(shares: list[float], temperature: float) -> float:
+        if not shares:
+            return 0.0
+        if temperature <= 0:
+            raise ValueError("ACE temperature must be positive")
+        n = len(shares)
+        if n <= 1:
+            return 0.0
+        scaled = [s / temperature for s in shares]
+        m = max(scaled)
+        exps = [math.exp(x - m) for x in scaled]
+        z = sum(exps)
+        ps = [e / z for e in exps]
+        h = -sum(p * math.log(p) for p in ps if p > 0)
+        return h / math.log(n)
+
+    def _severity_values(
+        self,
+        agent_ids: tuple[str, ...],
+        votes: list[Any],
+        shares: dict[str, float],
+    ) -> list[float]:
+        """Project each vote onto a severity scalar."""
+        out: list[float] = []
+        for v in votes:
+            src = getattr(v, "voter_id", None)
+            tgt = getattr(v, "voted_for", None)
+            if src is None or tgt is None or src not in agent_ids or tgt not in agent_ids:
+                continue
+            if self._rater is None:
+                sev = _share_based_severity_rater(
+                    voter_id=src, voted_for=tgt,
+                    answer_labels=list(agent_ids),
+                    reason_text=getattr(v, "reason", "") or "",
+                    vote_shares=shares,
+                )
+            else:
+                sev = self._rater(
+                    voter_id=src, voted_for=tgt,
+                    answer_labels=list(agent_ids),
+                    reason_text=getattr(v, "reason", "") or "",
+                )
+            out.append(max(0.0, min(1.0, float(sev))))
+        return out
+
+    @staticmethod
+    def _winner(
+        agent_ids: tuple[str, ...],
+        shares: dict[str, float],
+        votes: list[Any],
+    ) -> tuple[str | None, float]:
+        if not shares:
+            return None, 0.0
+        # Basic rule: winner = argmax vote-share with tiebreak by deterministic
+        # order of agent_ids.
+        winner = max(agent_ids, key=lambda a: (shares[a], -agent_ids.index(a)))
+        return winner, shares[winner]
+
+    def _tdi(self, last: DifficultyMetrics | None, delta_mean: float, wfr: float) -> float:
+        if last is None:
+            return 0.0
+        lack = 1.0 - max(0.0, min(1.0, delta_mean))
+        coef = self.tdi_coefficients
+        raw = (
+            coef.alpha_ace * last.ace_norm
+            + coef.beta_csd * last.csd
+            + coef.gamma_lack_of_conv * lack
+            + coef.delta_wfr * wfr
+        )
+        return max(0.0, min(1.0, raw))
