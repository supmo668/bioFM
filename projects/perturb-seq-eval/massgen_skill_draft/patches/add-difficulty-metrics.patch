@@ -0,0 +1,190 @@
+"""Unit tests for the learning/difficulty_metrics observer.
+
+Strictly follows MassGen's TDD contract (CLAUDE.md): each test expresses one
+behaviour of the observer without exercising any LLM backend.
+"""
+
+from __future__ import annotations
+
+from dataclasses import dataclass
+
+import pytest
+
+from massgen.learning import DifficultyMetricsObserver, TDICoefficients
+
+
+@dataclass
+class FakeAnswer:
+    agent_id: str
+    content: str = ""
+
+
+@dataclass
+class FakeVote:
+    voter_id: str
+    voted_for: str
+    reason: str = ""
+
+
+def _default_agents() -> list[FakeAnswer]:
+    return [FakeAnswer(a) for a in ("gpt5", "claude", "gemini", "grok", "llama")]
+
+
+class TestVoteShare:
+    def test_all_votes_for_one_agent_max_share(self) -> None:
+        agents = _default_agents()
+        votes = [FakeVote(a.agent_id, "gpt5", reason="clearly best")
+                 for a in agents if a.agent_id != "gpt5"]
+        obs = DifficultyMetricsObserver()
+        rec = obs.on_round_end(0, agents, votes)
+        assert rec.max_vote_share == pytest.approx(1.0)
+        assert rec.winner == "gpt5"
+
+    def test_split_vote_low_concentration(self) -> None:
+        agents = _default_agents()
+        votes = [
+            FakeVote("claude", "gpt5"),
+            FakeVote("gemini", "claude"),
+            FakeVote("grok", "gemini"),
+            FakeVote("llama", "grok"),
+            FakeVote("gpt5", "llama"),
+        ]
+        obs = DifficultyMetricsObserver()
+        rec = obs.on_round_end(0, agents, votes)
+        assert rec.max_vote_share == pytest.approx(0.2)
+
+
+class TestACENorm:
+    def test_uniform_shares_max_entropy(self) -> None:
+        agents = _default_agents()
+        votes = [
+            FakeVote("claude", "gpt5"),
+            FakeVote("gemini", "claude"),
+            FakeVote("grok", "gemini"),
+            FakeVote("llama", "grok"),
+            FakeVote("gpt5", "llama"),
+        ]
+        obs = DifficultyMetricsObserver()
+        rec = obs.on_round_end(0, agents, votes)
+        # 5 equal vote-shares → max ACE (close to 1.0 after softmax).
+        assert rec.ace_norm > 0.99
+
+    def test_concentrated_share_lower_entropy(self) -> None:
+        agents = _default_agents()
+        votes = [FakeVote(a.agent_id, "gpt5") for a in agents if a.agent_id != "gpt5"]
+        obs = DifficultyMetricsObserver()
+        rec = obs.on_round_end(0, agents, votes)
+        # All peers vote for gpt5 → concentrated distribution → ACE below uniform.
+        assert rec.ace_norm < 1.0
+
+
+class TestSeverityDefaultRater:
+    def test_unanimous_winner_has_zero_severity(self) -> None:
+        agents = _default_agents()
+        votes = [FakeVote(a.agent_id, "gpt5") for a in agents if a.agent_id != "gpt5"]
+        obs = DifficultyMetricsObserver()
+        rec = obs.on_round_end(0, agents, votes)
+        # Default rater: sev = 1 - vote_share(target); gpt5 has share 1.0 so sev = 0.
+        assert rec.csd == 0.0
+
+    def test_split_vote_nonzero_csd(self) -> None:
+        agents = _default_agents()
+        votes = [
+            FakeVote("claude", "gpt5"),
+            FakeVote("gemini", "claude"),
+            FakeVote("grok", "gemini"),
+            FakeVote("llama", "grok"),
+        ]
+        obs = DifficultyMetricsObserver()
+        rec = obs.on_round_end(0, agents, votes)
+        # CSD should be small (same default severities per target) but finite.
+        assert rec.csd >= 0.0
+
+
+class TestCustomSeverityRater:
+    def test_llm_rater_is_called_with_reason(self) -> None:
+        calls: list[str] = []
+
+        def rater(*, voter_id: str, voted_for: str,
+                  answer_labels, reason_text: str) -> float:
+            calls.append(reason_text)
+            return 0.8
+
+        agents = _default_agents()
+        votes = [
+            FakeVote("claude", "gpt5", reason="better tools"),
+            FakeVote("gemini", "gpt5", reason="higher quality"),
+        ]
+        obs = DifficultyMetricsObserver(rater=rater)
+        obs.on_round_end(0, agents, votes)
+        assert calls == ["better tools", "higher quality"]
+
+    def test_rater_output_is_clipped_to_unit_interval(self) -> None:
+        def wild(*, voter_id, voted_for, answer_labels, reason_text):
+            return 3.7
+        agents = _default_agents()
+        votes = [FakeVote("claude", "gpt5", reason="x")]
+        obs = DifficultyMetricsObserver(rater=wild)
+        rec = obs.on_round_end(0, agents, votes)
+        # Severity was clipped to [0, 1]; CSD is finite and non-negative.
+        assert rec.csd >= 0.0
+
+
+class TestRunLevelMetrics:
+    def test_converging_run_has_negative_delta_ace(self) -> None:
+        agents = _default_agents()
+        obs = DifficultyMetricsObserver()
+        # Round 0: flat split
+        obs.on_round_end(0, agents, [
+            FakeVote("claude", "gpt5"), FakeVote("gemini", "claude"),
+            FakeVote("grok", "gemini"), FakeVote("llama", "grok"),
+        ])
+        # Round 1: concentrated on gpt5
+        obs.on_round_end(1, agents, [
+            FakeVote("claude", "gpt5"), FakeVote("gemini", "gpt5"),
+            FakeVote("grok", "gpt5"), FakeVote("llama", "gpt5"),
+        ])
+        snap = obs.snapshot()
+        assert snap.delta_ace < 0
+
+    def test_winner_flip_rate_counts_changes(self) -> None:
+        agents = _default_agents()
+        obs = DifficultyMetricsObserver()
+        for i, target in enumerate(["gpt5", "claude", "gpt5"]):
+            obs.on_round_end(i, agents, [
+                FakeVote("claude" if target != "claude" else "gemini", target),
+                FakeVote("grok", target), FakeVote("llama", target),
+            ])
+        snap = obs.snapshot()
+        # 3 rounds, winners were [gpt5, claude, gpt5] → 2 flips / 2 = 1.0.
+        assert snap.winner_flip_rate == pytest.approx(1.0)
+
+    def test_tdi_is_bounded(self) -> None:
+        agents = _default_agents()
+        obs = DifficultyMetricsObserver()
+        obs.on_round_end(0, agents, [FakeVote("claude", "gpt5")])
+        snap = obs.snapshot()
+        assert 0.0 <= snap.tdi <= 1.0
+
+
+class TestTDICoefficientValidation:
+    def test_coefficients_must_sum_to_one(self) -> None:
+        with pytest.raises(ValueError):
+            TDICoefficients(alpha_ace=0.5, beta_csd=0.5,
+                            gamma_lack_of_conv=0.5, delta_wfr=0.5)
+
+    def test_default_coefficients_sum_to_one(self) -> None:
+        c = TDICoefficients()
+        assert abs(c.alpha_ace + c.beta_csd + c.gamma_lack_of_conv + c.delta_wfr - 1.0) < 1e-6
+
+
+class TestAsRunTrace:
+    def test_json_shape(self) -> None:
+        agents = _default_agents()
+        obs = DifficultyMetricsObserver()
+        obs.on_round_end(0, agents, [FakeVote("claude", "gpt5")])
+        trace = obs.as_run_trace()
+        assert set(trace.keys()) == {"per_round", "delta_ace",
+                                       "delta_mean_share",
+                                       "winner_flip_rate", "tdi"}
+        assert trace["per_round"][0]["round_index"] == 0
