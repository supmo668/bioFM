+"""Learning-system submodule for MassGen.
+
+Today this module exposes a single capability:
+
+* :mod:`massgen.learning.difficulty_metrics` — an observer over
+  ``CoordinationTracker`` events that emits Agent Confidence Entropy (ACE),
+  Critique Severity Dispersion (CSD), round-over-round convergence signals,
+  Winner Flip Rate (WFR), and a composite Task Difficulty Index (TDI).
+
+The module is enabled via the ``orchestrator.coordination`` config key
+``learning_difficulty_metrics``. It is a no-op until that flag is set.
+"""
+
+from massgen.learning.difficulty_metrics import (
+    ACEConfig,
+    DifficultyMetrics,
+    DifficultyMetricsObserver,
+    TDICoefficients,
+)
+
+__all__ = [
+    "ACEConfig",
+    "DifficultyMetrics",
+    "DifficultyMetricsObserver",
+    "TDICoefficients",
+]
