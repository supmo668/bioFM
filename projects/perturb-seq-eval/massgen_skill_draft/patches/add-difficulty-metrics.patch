+# Example MassGen config enabling the difficulty-metrics learning observer.
+#
+# Run with:
+#   uv run massgen --automation --config massgen/configs/learning/difficulty_metrics.yaml "How should we design a CRISPRi screen for the IRE1 branch of the UPR?"
+#
+# When `learning_difficulty_metrics: true`, the orchestrator attaches a
+# `DifficultyMetricsObserver` that consumes AgentAnswer + AgentVote records per
+# round and persists ACE/CSD/WFR/TDI to `artifacts/difficulty_metrics.json`.
+
+agents:
+  - id: "gpt5"
+    backend:
+      type: "openai"
+      model: "gpt-5"
+  - id: "claude"
+    backend:
+      type: "claude"
+      model: "claude-4.5-sonnet"
+  - id: "gemini"
+    backend:
+      type: "gemini"
+      model: "gemini-2.5-pro"
+
+orchestrator:
+  coordination:
+    # === Required flag: enables the observer ===
+    learning_difficulty_metrics: true
+
+    # Optional: override the softmax temperature used by ACE (default 1.0;
+    # lower values sharpen the distribution).
+    learning_difficulty_metrics_ace_temperature: 1.0
+
+    # Optional: override the TDI convex-combination weights. They must sum
+    # to 1.0 or the observer will refuse to start.
+    learning_difficulty_metrics_tdi_alpha_ace: 0.35
+    learning_difficulty_metrics_tdi_beta_csd: 0.25
+    learning_difficulty_metrics_tdi_gamma_lack_of_conv: 0.25
+    learning_difficulty_metrics_tdi_delta_wfr: 0.15
