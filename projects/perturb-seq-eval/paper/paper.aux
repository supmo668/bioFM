\@writefile{toc}{\contentsline {subsection}{\numberline {7.1}The metrics individually rank task difficulty --- with one signal dominating}{5}{subsection.7.1}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Single-feature correlation with the latent difficulty label $d$, $n\!=\!300$. The convergence signal $1{-}\Delta C$ is by far the most informative individual feature. The default-coefficient TDI has moderate rank correlation but negative univariate $R^2$, indicating a location-scale mismatch that the calibration step fixes (see Table\nobreakspace  {}\ref  {tab:calib}).\relax }}{5}{table.1}\protected@file@percent }
\newlabel{tab:corr}{{1}{5}{Single-feature correlation with the latent difficulty label $d$, $n\!=\!300$. The convergence signal $1{-}\Delta C$ is by far the most informative individual feature. The default-coefficient TDI has moderate rank correlation but negative univariate $R^2$, indicating a location-scale mismatch that the calibration step fixes (see Table~\ref {tab:calib}).\relax }{table.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Per-task metric values versus latent difficulty ($n{=}300$). The TDI panel uses default weights, which under-weight $1-\Delta C$.\relax }}{5}{figure.caption.8}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:metric_vs_d}{{1}{5}{Per-task metric values versus latent difficulty ($n{=}300$). The TDI panel uses default weights, which under-weight $1-\Delta C$.\relax }{figure.caption.8}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.2}Calibration closes the gap between default and data-driven TDI}{5}{subsection.7.2}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Default-versus-calibrated TDI on the $60$-task held-out split. Ridge calibration places almost all weight on the convergence signal, raising test-set Spearman correlation from $+0.52$ to $+0.92$.\relax }}{5}{table.2}\protected@file@percent }
\newlabel{tab:calib}{{2}{5}{Default-versus-calibrated TDI on the $60$-task held-out split. Ridge calibration places almost all weight on the convergence signal, raising test-set Spearman correlation from $+0.52$ to $+0.92$.\relax }{table.2}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.3}The probe partially identifies difficulty, but not post-hoc TDI}{5}{subsection.7.3}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Held-out generalisation of the single-round probe. Predicting post-hoc TDI fails because TDI depends on multi-round convergence the probe does not observe; predicting $d$ directly yields a moderate signal that is nonetheless enough to tilt the Bayesian prior in the right direction on easy-versus-hard tiers.\relax }}{5}{table.3}\protected@file@percent }
\newlabel{tab:probe}{{3}{5}{Held-out generalisation of the single-round probe. Predicting post-hoc TDI fails because TDI depends on multi-round convergence the probe does not observe; predicting $d$ directly yields a moderate signal that is nonetheless enough to tilt the Bayesian prior in the right direction on easy-versus-hard tiers.\relax }{table.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Left: default-versus-calibrated TDI rank correlation with $d$. Right: Spearman $\rho $ between each single feature and $d$. Red bars mark features that individually contribute $\rho \le 0.2$.\relax }}{6}{figure.caption.9}\protected@file@percent }
\newlabel{fig:calib}{{2}{6}{Left: default-versus-calibrated TDI rank correlation with $d$. Right: Spearman $\rho $ between each single feature and $d$. Red bars mark features that individually contribute $\rho \le 0.2$.\relax }{figure.caption.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Probe-to-$d$ ridge prediction on $n{=}300$ tasks. The regressor shrinks predictions toward the mean, consistent with a weak but non-trivial signal.\relax }}{6}{figure.caption.10}\protected@file@percent }
\newlabel{fig:probe}{{3}{6}{Probe-to-$d$ ridge prediction on $n{=}300$ tasks. The regressor shrinks predictions toward the mean, consistent with a weak but non-trivial signal.\relax }{figure.caption.10}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.4}Held-out utility scales monotonically with $N$ but at tier-dependent rates}{6}{subsection.7.4}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Mean $\pm $ SEM held-out AUROC as a function of agent count $N$ and difficulty tier, with rounds fixed at $R{=}2$. Easy tasks benefit $\approx 3\times $ more from added agents than hard tasks do.\relax }}{6}{table.4}\protected@file@percent }
\newlabel{tab:scaling}{{4}{6}{Mean $\pm $ SEM held-out AUROC as a function of agent count $N$ and difficulty tier, with rounds fixed at $R{=}2$. Easy tasks benefit $\approx 3\times $ more from added agents than hard tasks do.\relax }{table.4}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.5}Pareto frontier: adaptive is competitive, uniform wins at large budgets}{6}{subsection.7.5}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Held-out mean AUROC at selected compute budgets. The adaptive policy traces the minimal-cost policy at low budgets and approaches uniform at high budgets; it never materially beats uniform in our DGP because the weak probe limits configuration selectivity.\relax }}{6}{table.5}\protected@file@percent }
\newlabel{tab:pareto}{{5}{6}{Held-out mean AUROC at selected compute budgets. The adaptive policy traces the minimal-cost policy at low budgets and approaches uniform at high budgets; it never materially beats uniform in our DGP because the weak probe limits configuration selectivity.\relax }{table.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Utility scaling with $N$ stratified by difficulty tier. Hard-tier curves plateau well below easy-tier curves, arguing for adaptive rather than uniform allocation --- \emph  {provided} difficulty is observable before commit.\relax }}{7}{figure.caption.11}\protected@file@percent }
\newlabel{fig:scaling}{{4}{7}{Utility scaling with $N$ stratified by difficulty tier. Hard-tier curves plateau well below easy-tier curves, arguing for adaptive rather than uniform allocation --- \emph {provided} difficulty is observable before commit.\relax }{figure.caption.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Mean held-out AUROC versus compute-budget proxy. The adaptive policy sits between minimal and uniform across the budget range; closing the gap requires a richer probe (Section\nobreakspace  {}\ref  {sec:limits}).\relax }}{7}{figure.caption.12}\protected@file@percent }
\newlabel{fig:pareto}{{5}{7}{Mean held-out AUROC versus compute-budget proxy. The adaptive policy sits between minimal and uniform across the budget range; closing the gap requires a richer probe (Section~\ref {sec:limits}).\relax }{figure.caption.12}{}}
